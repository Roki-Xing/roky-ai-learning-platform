generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id             String           @id @default(cuid())
  userId         String           @unique
  displayName    String?
  level          String           @default("beginner")
  goal           String           @default("ai_general")
  dailyMinutes   Int              @default(30)
  language       String           @default("zh")
  difficulty     String           @default("standard")
  preferredAreas Json?
  preferredTermSlugs Json?
  preferredEntitySlugs Json?
  knowledgeAvoidDays Int          @default(7)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  timeZone       String           @default("Asia/Shanghai")
  dailyPlans     DailyPlan[]
  flashcards     Flashcard[]
  learningProjects LearningProject[]
  notes          Note[]
  topicStates    UserTopicState[]
}

model Domain {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  weight      Int      @default(10)
  createdAt   DateTime @default(now())
  topics      Topic[]
}

model Topic {
  id            String   @id @default(cuid())
  domainId      String
  parentId      String?
  title         String
  slug          String   @unique
  summary       String?
  depthLevel    Int      @default(0)
  prerequisites Json?
  createdAt     DateTime @default(now())
  lessons       Lesson[]
  domain        Domain   @relation(fields: [domainId], references: [id])

  @@index([domainId])
  @@index([parentId])
}

model Lesson {
  id               String         @id @default(cuid())
  topicId          String
  title            String
  summary          String
  contentMarkdown  String
  difficulty       String
  estimatedMinutes Int            @default(30)
  objectives       Json
  keyTerms         Json
  examples         Json?
  commonMistakes   Json?
  connections      Json?
  createdBy        String         @default("ai")
  createdAt        DateTime       @default(now())
  dailyPlans       DailyPlan[]
  flashcards       Flashcard[]
  topic            Topic          @relation(fields: [topicId], references: [id])
  quizzes          QuizQuestion[]

  @@index([topicId])
  @@index([createdAt])
}

model DailyPlan {
  id              String      @id @default(cuid())
  userId          String
  lessonId         String
  date            DateTime
  status          String      @default("planned")
  startedAt       DateTime?
  completedAt     DateTime?
  reflection      String?
  guidedProgress  Json?
  score           Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  localDate       String
  source          String?
  schemaVersion   String?
  isTest          Boolean     @default(false)
  archivedAt      DateTime?
  selectedTopic   String?
  selectedDomain  String?
  selectionReason String?
  generationJobId String?
  lesson          Lesson      @relation(fields: [lessonId], references: [id])
  user            UserProfile @relation(fields: [userId], references: [userId])

  @@index([userId, localDate, isTest, archivedAt])
  @@index([lessonId])
  @@index([date])
  @@index([localDate])
  @@index([source])
  @@index([schemaVersion])
}

model QuizQuestion {
  id          String        @id @default(cuid())
  lessonId    String
  type        String
  question    String
  options     Json?
  answer      Json
  explanation String
  difficulty  String        @default("standard")
  createdAt   DateTime      @default(now())
  attempts    QuizAttempt[]
  lesson      Lesson        @relation(fields: [lessonId], references: [id])

  @@index([lessonId])
  @@index([createdAt])
}

model QuizAttempt {
  id         String       @id @default(cuid())
  questionId String
  userId     String
  userAnswer Json
  isCorrect  Boolean
  createdAt  DateTime     @default(now())
  question   QuizQuestion @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@index([userId])
  @@index([createdAt])
}

model Misconception {
  id              String    @id @default(cuid())
  userId          String
  questionId      String?
  codeSubmissionId String?
  lessonId        String
  topicId         String?
  localDate       String?
  source          String    @default("quiz")
  sourceKey       String?   @unique
  summary         String
  prompt          String
  expectedAnswer  Json?
  userAnswer      Json?
  explanation     String?
  status          String    @default("open")
  occurrenceCount Int       @default(1)
  lastAttemptAt   DateTime  @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
  @@index([codeSubmissionId])
  @@index([lessonId])
  @@index([topicId])
  @@index([source])
  @@index([status])
  @@index([lastAttemptAt])
}

model CodeSubmission {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  localDate String
  language  String   @default("python")
  code      String
  status    String   @default("submitted")
  aiFeedback String?
  feedbackJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId, localDate])
  @@index([userId])
  @@index([lessonId])
  @@index([localDate])
}

model CodeFeedback {
  id           String   @id @default(cuid())
  submissionId String   @unique
  userId       String
  lessonId     String
  localDate    String
  provider     String   @default("template")
  status       String   @default("success")
  overall      String?
  summary      String
  strengths    Json?
  issues       Json?
  suggestions  Json?
  hints        Json?
  suggestedTests Json?
  flashcards   Json?
  feedbackJson Json?
  nextSteps    Json?
  raw          Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([lessonId])
  @@index([localDate])
  @@index([provider])
  @@index([status])
  @@index([updatedAt])
}

model ThoughtReview {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String?
  mode           String
  rawText        String
  normalizedText String?
  mainClaim      String?
  reviewJson     Json
  generatedCards Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([lessonId])
  @@index([mode])
  @@index([createdAt])
}

model VoiceNote {
  id               String   @id @default(cuid())
  userId           String
  lessonId         String?
  mode             String
  audioUrl         String?
  transcript       String
  editedTranscript String?
  thoughtReviewId  String?
  noteId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([lessonId])
  @@index([mode])
  @@index([thoughtReviewId])
  @@index([noteId])
  @@index([createdAt])
}

model Flashcard {
  id           String      @id @default(cuid())
  userId       String
  lessonId     String?
  front        String
  back         String
  type         String      @default("concept")
  tags         Json?
  difficulty   Int         @default(3)
  dueAt        DateTime    @default(now())
  intervalDays Int         @default(1)
  reviewCount  Int         @default(0)
  correctCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lesson       Lesson?     @relation(fields: [lessonId], references: [id])
  user         UserProfile @relation(fields: [userId], references: [userId])
  reviewLogs   ReviewLog[]

  @@index([userId])
  @@index([lessonId])
  @@index([dueAt])
}

model ReviewLog {
  id          String    @id @default(cuid())
  flashcardId String
  rating      String
  nextDueAt   DateTime
  createdAt   DateTime  @default(now())
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id])

  @@index([flashcardId])
  @@index([createdAt])
}

model Note {
  id        String      @id @default(cuid())
  userId    String
  lessonId  String?
  title     String
  content   String
  tags      Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      UserProfile @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([lessonId])
}

model UserTopicState {
  id            String      @id @default(cuid())
  userId        String
  topicId       String
  masteryLevel  Int         @default(0)
  exposureCount Int         @default(0)
  lastStudiedAt DateTime?
  weaknessScore Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          UserProfile @relation(fields: [userId], references: [userId])

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}

model AiGenerationJob {
  id         String   @id @default(cuid())
  userId     String?
  type       String
  status     String   @default("pending")
  input      Json
  output     Json?
  error      String?
  model      String?
  tokenUsage Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model CurriculumDecisionLog {
  id             String   @id @default(cuid())
  userId         String
  localDate      String
  isTest         Boolean  @default(false)
  domain         String
  topic          String
  reason         String
  inputSnapshot  Json
  scoreBreakdown Json?
  createdAt      DateTime @default(now())

  @@unique([userId, localDate, isTest])
  @@index([userId])
  @@index([localDate])
  @@index([domain])
  @@index([topic])
}

model GlossaryTerm {
  id             String   @id @default(cuid())
  slug           String   @unique
  abbreviation   String?
  fullName       String
  chineseName    String?
  category       String
  oneLine        String
  explanation    String
  whyImportant   String?
  relatedTerms   Json?
  commonMistakes Json?
  examples       Json?
  sourceRefs     Json?
  difficulty     String   @default("beginner")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([difficulty])
  @@index([updatedAt])
}

model KnowledgeEntity {
  id                  String   @id @default(cuid())
  type                String
  name                String
  slug                String   @unique
  aliases             Json?
  oneLine             String
  whyImportant        String?
  representativeWorks Json?
  relatedTerms        Json?
  timeline            Json?
  sourceRefs          Json?
  lastVerifiedAt      DateTime?
  confidence          String   @default("medium")
  selfCheckQuestion   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([type])
  @@index([confidence])
  @@index([lastVerifiedAt])
  @@index([updatedAt])
}

model LearningProject {
  id             String             @id @default(cuid())
  userId         String
  templateSlug   String?
  type           String
  title          String
  description    String
  difficulty     String
  status         String             @default("planned")
  summary        String?
  relatedTopics  Json?
  relatedLessons Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           UserProfile        @relation(fields: [userId], references: [userId])
  milestones     ProjectMilestone[]

  @@unique([userId, templateSlug])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([updatedAt])
}

model ProjectMilestone {
  id               String          @id @default(cuid())
  projectId        String
  userId           String
  position         Int
  title            String
  task             String
  codePrompt       String
  reflectionPrompt String
  status           String          @default("planned")
  relatedTopics    Json?
  lessonId         String?
  noteId           String?
  codeSubmissionId String?
  code             String?
  note             String?
  reflection       String?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          LearningProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, position])
  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([lessonId])
  @@index([noteId])
  @@index([codeSubmissionId])
  @@index([updatedAt])
}
